# Glab Production Environment — 192.168.37.206
# Copy to .env before deploying: cp .env.production .env
# Then replace all CHANGE_ME values.

# Database
DATABASE_URL=postgres://glab:CHANGE_ME@postgres:5432/glab?sslmode=disable
POSTGRES_USER=glab
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=glab

# Redis
REDIS_URL=redis://redis:6379

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_EXPIRY=604800

# API
PORT=8080
CORS_ORIGIN=https://glab.geovendas.local

# Frontend
NEXT_PUBLIC_API_URL=https://glab.geovendas.local
NEXT_PUBLIC_WS_URL=wss://glab.geovendas.local

# Files
UPLOAD_DIR=/data/uploads
